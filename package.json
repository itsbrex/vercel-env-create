{
  "name": "vercel-env-create",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Generate and sync Next.js/Vercel-friendly .env templates from referenced variables.",
  "author": "itsbrex <github@itsbrex.dev> (https://itsbrex.dev)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vercel-env-create": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "ci": "pnpm lint && pnpm test && pnpm typecheck && pnpm build",
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts src/cli.ts --dts --format cjs,esm --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts test/**/*.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier src test --write",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.13.9",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.34.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@9.15.3",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "cli",
    "environment-variables",
    "env",
    "push",
    "vercel",
    "env-file"
  ],
  "homepage": "https://github.com/itsbrex/vercel-env-create",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsbrex/vercel-env-create.git"
  },
  "bugs": "https://github.com/itsbrex/vercel-env-create/issues",
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown --cache"
  }
}
